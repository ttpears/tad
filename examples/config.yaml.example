# tad app config. Copy to ~/.config/tad/config.yaml.
#
# theme: one of the built-in names, or a custom inline palette.
#
# Built-in names:
#   tokyonight  tokyonight-storm  dracula  nord  gruvbox  catppuccin
#   solarized-dark  onedark  terminal  (terminal uses your 16-color palette)

theme: tokyonight

# To override individual colors, use an inline map instead of a name.
# Any keys you omit fall back to the tokyonight defaults. Values are hex
# RGB ("#RRGGBB" or "RRGGBB").
#
# theme:
#   fg: "#a9b1d6"
#   muted: "#565f89"
#   accent: "#7aa2f7"
#   accent_bold: "#bb9af7"
#   success: "#9ece6a"
#   warning: "#e0af68"
#   error: "#f7768e"
#   selection_bg: "#2a2e42"
#   border: "#3b4261"
