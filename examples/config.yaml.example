# tad config. Copy to ~/.config/tad/config.yaml.
#
# Unified config: theme, ui prefs, and groups all live in this one file.
# Pre-v0.10 layouts split groups out into ~/.config/tad/groups.yaml; on
# first launch tad auto-migrates that into the `groups:` section here.

# ---- theme ----
# A built-in name, or a custom inline palette. Built-ins:
#   tokyonight  tokyonight-storm  dracula  nord  gruvbox  catppuccin
#   solarized-dark  onedark  terminal  (terminal uses your 16-color palette)
theme: tokyonight

# To override individual colors, use an inline map instead of a name. Any
# key you omit falls back to the tokyonight defaults. Values are hex RGB
# ("#RRGGBB" or "RRGGBB").
#
# theme:
#   fg: "#a9b1d6"
#   muted: "#565f89"
#   accent: "#7aa2f7"
#   accent_bold: "#bb9af7"
#   success: "#9ece6a"
#   warning: "#e0af68"
#   error: "#f7768e"
#   selection_bg: "#2a2e42"
#   border: "#3b4261"

# ---- ui ----
# All keys have sensible defaults; uncomment only what you want to override.
#
# ui:
#   attention_idle_secs: 30        # Active→Idle threshold for the mtime fallback
#                                  # used by `tad watch` when transcripts aren't
#                                  # parseable. Lower = faster marker, more noise.
#   awaiting_freshness_secs: 600   # AwaitingInput agents older than this are
#                                  # treated as "user walked away" and excluded
#                                  # from the `tad status` "waiting" count.
#   snooze_intervals_secs: [300, 1800, 7200]   # offered in the dashboard 's' modal
#   notify_on_blocked: true        # desktop notification when an agent turns
#                                  # blocked (needs your input). Default true;
#                                  # set false to disable.

# ---- groups ----
# Multi-host configurations for `tad -g <name>` / the dashboard Groups view.
# See examples/groups.yaml.example for the full schema and more examples.
groups:
  web:
    layout: panes              # panes | synced-panes | windows | browse
    hosts:
      - web-1.example.com
      - web-2.example.com
      - web-3.example.com
