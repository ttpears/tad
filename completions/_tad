#compdef tad
# zsh completion for tad. Source of truth: `tad complete` and `tad groups list`.

_tad() {
   # ---- top-level (position 2) ----
   if (( CURRENT == 2 )); then
      local -a subs
      subs=(
         'groups:manage groups (list, hosts, add, rm, edit)'
         'config:groups editor (TUI)'
         'tmux-keybind:print/install a tmux popup binding for the dashboard'
         'status:one-line summary of running Claude Code agents (for tmux status-line)'
         'watch:long-running poller — auto-popup the dashboard on Active→Idle'
      )
      local -a attached detached state rest
      while IFS=$'\t' read -r state rest; do
         case $state in
            attached) attached+=("$rest") ;;
            detached) detached+=("$rest") ;;
         esac
      done < <(tad complete 2>/dev/null)
      # `tad complete-hosts` emits `name<TAB>source-tag`; _describe wants
      # `name:description`, so split on the tab and escape colons in the
      # name (feeding raw lines made the tab part of the candidate word).
      local -a hosts
      local hname hdesc
      while IFS=$'\t' read -r hname hdesc; do
         [[ -n $hname ]] || continue
         if [[ -n $hdesc ]]; then
            hosts+=("${hname//:/\\:}:${hdesc}")
         else
            hosts+=("${hname//:/\\:}")
         fi
      done < <(tad complete-hosts 2>/dev/null)
      _describe -t commands 'command' subs
      _describe -t attached 'attached session' attached
      _describe -t detached 'detached session' detached
      _describe -t hosts 'host' hosts
      _values 'option' '-g[open a group]'
      return
   fi

   case ${words[2]} in
      -g)
         if (( CURRENT == 3 )); then
            _tad_groups
         elif (( CURRENT == 4 )); then
            local -a hosts
            hosts=("${(@f)$(tad groups hosts ${words[3]} 2>/dev/null)}")
            _describe -t hosts "host in ${words[3]}" hosts
         fi
         return
         ;;
      groups)
         _tad_groups_sub
         return
         ;;
   esac
}

# Completion inside `tad groups <sub>` ...
_tad_groups_sub() {
   if (( CURRENT == 3 )); then
      local -a subs=(
         'list:list known groups'
         'hosts:print hosts in a group'
         'add:add a group (interactive wizard if no args)'
         'rm:remove a group'
         'edit:open the groups file in $EDITOR'
      )
      _describe -t commands 'groups subcommand' subs
      return
   fi

   case ${words[3]} in
      hosts|rm)
         if (( CURRENT == 4 )); then
            _tad_groups
         elif (( CURRENT == 5 )) && [[ ${words[3]} == hosts ]]; then
            local -a hosts
            hosts=("${(@f)$(tad groups hosts ${words[4]} 2>/dev/null)}")
            _describe -t hosts "host in ${words[4]}" hosts
         fi
         ;;
      add)
         # tad groups add <name> <layout> <host>...
         # position 4 = NAME (free-form), 5 = LAYOUT, 6+ = HOSTS.
         if (( CURRENT == 5 )); then
            local -a layouts
            layouts=(
               'panes:single window, one pane per host'
               'synced-panes:panes with synchronize-panes default on in scripts'
               'windows:one window per host'
               'browse:list hosts only, no auto-open'
            )
            _describe -t layouts 'layout' layouts
         elif (( CURRENT >= 6 )); then
            local -a all_hosts g
            for g in "${(@f)$(tad groups list 2>/dev/null | cut -d: -f1)}"; do
               [[ -n $g ]] || continue
               all_hosts+=("${(@f)$(tad groups hosts $g 2>/dev/null)}")
            done
            all_hosts+=("${(@f)$(tad complete-hosts 2>/dev/null | cut -f1)}")
            _describe -t hosts 'known host' all_hosts
         fi
         ;;
   esac
}

_tad_groups() {
   local -a groups
   groups=("${(@f)$(tad groups list 2>/dev/null)}")
   _describe -t groups 'group' groups
}

zstyle ':completion:*:tad:*' group-order attached detached hosts commands
zstyle ':completion:*:tad:*' sort false

_tad "$@"
